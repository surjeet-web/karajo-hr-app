# Karajo HR API - Environment Variables
# Copy this file to .env and fill in the values

# JWT Secret (for production token signing)
JWT_SECRET=your-secret-key-here

# OpenAI API Key (for AI chat - optional, uses mock responses by default)
# OPENAI_API_KEY=sk-xxx

# Database URL (for production - Turso/Supabase/etc)
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# App URL (for CORS)
# APP_URL=https://your-app.expo.app
